{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "soc",
    "siem",
    "ansible",
    "docker"
  ],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(up, instance)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "weekStart": "",
  "title": "Security & SIEM",
  "uid": "security-siem",
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "High severity alerts",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "elasticsearch",
        "uid": "Elasticsearch"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "Elasticsearch"
          },
          "query": "rule.level:>=10",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": []
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Medium severity alerts",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "elasticsearch",
        "uid": "Elasticsearch"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "Elasticsearch"
          },
          "query": "rule.level:[7 TO 9]",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": []
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Authentication failures",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "sum(count_over_time({job=~\".+\"} |~ \"failed|failure|invalid|denied\" [15m]))",
          "queryType": "range"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Alert trend",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "elasticsearch",
        "uid": "Elasticsearch"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "Elasticsearch"
          },
          "query": "*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": []
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Recent Wazuh/security events",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "{job=~\"wazuh|security|auth|syslog\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "sortOrder": "Descending"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Top noisy hosts",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "elasticsearch",
        "uid": "Elasticsearch"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "elasticsearch",
            "uid": "Elasticsearch"
          },
          "query": "*",
          "alias": "",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": []
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Security triage notes",
      "type": "text",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": null,
      "targets": [],
      "options": {
        "mode": "markdown",
        "content": "### Triage volgorde\n1. Kritieke Wazuh alerts\n2. Authenticatie-fouten\n3. Afwijkende logpieken\n4. Betrokken host/service bepalen\n5. Actie vastleggen"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ],
  "description": "Dashboard voor Wazuh/Elasticsearch security events en logtriage."
}