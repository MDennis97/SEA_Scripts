global_defs {
    enable_script_security
    script_user root
}

vrrp_script chk_keycloak {
    script "/usr/local/bin/check-keycloak.sh"
    interval 2
    timeout 2
    fall 2
    rise 1
}

vrrp_instance VI_1 {
    state {{ keepalived_state | default('BACKUP') }}
    interface {{ keepalived_interface }}
    virtual_router_id {{ keepalived_router_id }}
    priority {{ keepalived_priority | default(100) }}
    advert_int 1

{% if keepalived_use_unicast | default(true) %}
    unicast_src_ip {{ ansible_host | default(ansible_default_ipv4.address) }}
    unicast_peer {
{% for host in groups['identity'] if host != inventory_hostname %}
        {{ hostvars[host].ansible_host | default(host) }}
{% endfor %}
    }
{% endif %}

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    virtual_ipaddress {
        {{ keepalived_virtual_ip }}/{{ keepalived_virtual_prefix }} dev {{ keepalived_interface }}
    }

    track_script {
        chk_keycloak
    }
}
