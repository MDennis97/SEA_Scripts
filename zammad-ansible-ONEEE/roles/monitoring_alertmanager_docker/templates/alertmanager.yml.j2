global:
  resolve_timeout: 5m

route:
  receiver: zammad
  group_by: ["alertname", "instance"]
  group_wait: 10s
  group_interval: 1m
  repeat_interval: 4h

receivers:
  - name: zammad
    webhook_configs:
      - url: "http://{{ zammad_ip }}:{{ zammad_bridge_port }}/webhook/alertmanager"
        send_resolved: true
